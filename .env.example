# Agent Configuration (for running on your beaker machine)

# Required: WebSocket URL of the router
ROUTER_URL=wss://assisted-bot.apps.ext.spoke.prod.us-east-1.aws.paas.redhat.com/ws/agent

# Optional: Working directory for Claude (default: current directory)
WORKING_DIRECTORY=.

# Optional: Permission mode (default|bypass|allowEdits|plan)
PERMISSION_MODE=default

# Optional: Override Claude model (empty = use CLI default)
CLAUDE_MODEL=

# Optional: Max conversation turns per request
CLAUDE_MAX_TURNS=50

# Optional: Anthropic API key (if not using default auth)
# ANTHROPIC_API_KEY=sk-ant-...
