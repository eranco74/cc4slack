# Slack Configuration
# Bot token (xoxb-...) - OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token (xapp-...) - Basic Information > App-Level Tokens
# Must have connections:write scope for Socket Mode
SLACK_APP_TOKEN=xapp-your-app-token

# Signing secret - Basic Information > Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Configuration
# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum conversation turns before stopping
CLAUDE_MAX_TURNS=50

# Tool Approval Settings
# Skip ALL permission prompts (dangerous - Claude can run any command/edit any file)
# Set to true to allow Claude full autonomy in the workspace
DANGEROUSLY_SKIP_PERMISSIONS=false

# These are ignored if DANGEROUSLY_SKIP_PERMISSIONS=true
# Auto-approve read-only tools (Read, Glob, Grep, WebSearch, WebFetch)
AUTO_APPROVE_READ_ONLY=true

# Require user approval for Bash commands
REQUIRE_APPROVAL_FOR_BASH=true

# Require user approval for file writes/edits
REQUIRE_APPROVAL_FOR_WRITE=true

# Session Configuration
# Storage backend: "memory" or "redis"
SESSION_STORAGE=memory

# Session time-to-live in seconds (default: 24 hours)
SESSION_TTL_SECONDS=86400

# Redis URL (only needed if SESSION_STORAGE=redis)
# REDIS_URL=redis://localhost:6379/0

# Working Directory
# The directory Claude will work in (default: current directory)
WORKING_DIRECTORY=/workspace
